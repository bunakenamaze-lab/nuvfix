# ============================================================
# Koperasi NU Vibes - Environment Variables
# Copy file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# ---- MODE DATABASE ----
# Gunakan 'mysql' untuk MySQL/phpMyAdmin
# Gunakan 'sqlite' untuk SQLite (default, cocok untuk Railway)
DB_TYPE=sqlite

# ---- KONFIGURASI MySQL (aktif jika DB_TYPE=mysql) ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=u167347310_nuvibes26user
DB_PASSWORD=password
DB_NAME=u167347310_nuvibes26

# ---- KONFIGURASI SQLite (aktif jika DB_TYPE=sqlite) ----
DATABASE_PATH=./koperasi.db

# ---- UPLOAD ----
UPLOAD_PATH=./public/uploads

# ---- JWT ----
JWT_SECRET=koperasi-nu-vibes-secret-key-2024

# ---- SERVER ----
PORT=3000
NODE_ENV=production

# ---- APP URL ----
APP_URL=https://your-app.railway.app

# ---- EMAIL ----
EMAIL_HOST=mail.nukotabandung.or.id
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=nuvibes@nukotabandung.or.id
EMAIL_PASSWORD=your-email-password-here
EMAIL_FROM=Koperasi NU Vibes <nuvibes@nukotabandung.or.id>
ENABLE_EMAIL_NOTIFICATIONS=true
